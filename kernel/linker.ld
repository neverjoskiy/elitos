OUTPUT_FORMAT(elf32-i386)
ENTRY(_start)

SECTIONS
{
    . = 0x100000;

    .multiboot :
    {
        *(.multiboot)
    }

    .text :
    {
        *(.text*)
    }

    .data :
    {
        *(.data*)
    }

    .rodata :
    {
        *(.rodata*)
    }

    .bss :
    {
        *(COMMON)
        *(.bss*)
    }
}
